{
  "name": "somamcp",
  "version": "1.0.2",
  "description": "Framework for building MCP servers with telemetry, introspection, and backend abstraction",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./backend": {
      "types": "./dist/backend/index.d.ts",
      "import": "./dist/backend/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "validate": "ts-builds validate",
    "format": "ts-builds format",
    "format:check": "ts-builds format:check",
    "lint": "ts-builds lint",
    "lint:check": "ts-builds lint:check",
    "typecheck": "ts-builds typecheck",
    "test": "ts-builds test",
    "test:watch": "ts-builds test:watch",
    "test:coverage": "ts-builds test:coverage",
    "build": "ts-builds build",
    "dev": "ts-builds dev",
    "clean": "rimraf dist",
    "prepublishOnly": "pnpm validate"
  },
  "keywords": [
    "MCP",
    "server",
    "telemetry",
    "introspection",
    "backend-adapter"
  ],
  "author": "Jordan Burke",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "fastmcp": "^4.0.0",
    "functype": "^0.60.0",
    "functype-log": "^0.60.0",
    "hono": "^4.12.14",
    "zod": "^4.3.6"
  },
  "prettier": "ts-builds/prettier",
  "devDependencies": {
    "@types/node": "^24.12.2",
    "get-port-please": "^3.2.0",
    "ts-builds": "^2.7.0",
    "tsdown": "^0.21.9"
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319"
}
