{
  "name": "@somamcp-examples/time-server",
  "version": "0.0.0",
  "private": true,
  "description": "Sample MCP time server used as a testbed for somamcp",
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "start": "node dist/index.js",
    "start:stdio": "node dist/index.js --stdio",
    "dev": "tsx src/index.ts",
    "dev:stdio": "tsx src/index.ts --stdio",
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "somamcp": "workspace:*",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^24.12.2",
    "rimraf": "^6.0.1",
    "tsdown": "^0.21.9",
    "tsx": "^4.19.2",
    "typescript": "^5.6.0"
  }
}
